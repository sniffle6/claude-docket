{
  "name": "Memphis Noir Dark",
  "variant": "dark",
  "description": "A Memphis Design-inspired dark theme for dashboards. Olive-grey base with bold tomato red, lime green, and sunny yellow. Offset shadows, heavy outlines, geometric shapes. Full 80s energy, no purple, no blue.",

  "palette": {
    "primary": {
      "base": "#FF6B6B",
      "light": "#FF9B9B",
      "dark": "#E04545",
      "contrast": "#EDEADF"
    },
    "secondary": {
      "base": "#95E06C",
      "light": "#B8F098",
      "dark": "#6EBA45",
      "contrast": "#1A2A1A"
    },
    "accent": {
      "base": "#FFD166",
      "light": "#FFE299",
      "dark": "#E8B830",
      "contrast": "#2A2400"
    }
  },

  "semantic": {
