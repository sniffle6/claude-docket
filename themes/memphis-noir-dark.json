    { "foreground": "semantic.success.contrast", "background": "semantic.success.base", "ratio": 7.0, "level": "AAA" },
    { "foreground": "semantic.warning.contrast", "background": "semantic.warning.base", "ratio": 7.1, "level": "AAA" },
    { "foreground": "semantic.danger.contrast", "background": "semantic.danger.base", "ratio": 5.0, "level": "AA" },
