    "warning": { "base": "#FF9F43", "light": "#3A3228", "dark": "#E08830", "contrast": "#2A2A24" },
    "danger":  { "base": "#C73A3A", "light": "#3A2828", "dark": "#A83030", "contrast": "#FFFFFF" },
