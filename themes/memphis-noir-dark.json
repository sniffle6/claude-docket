    "subtle": "#36362E",
    "focus": "#FF6B6B"
  },

  "action": {
    "primary": {
      "background": "#FF6B6B",
      "text": "#1A1A16",
      "hover": "#E04545",
      "active": "#CC3A3A",
      "disabled-background": "#36362E",
      "disabled-text": "#5A5A50"
    },
    "secondary": {
      "background": "#3C3C34",
